# ─────────────────────────────────────────────────────────────────────────────
# ARJHBD Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────
#
# ⚠️ IMPORTANT: These MUST also be set in your deployment dashboard:
#   • Vercel:  Settings → Environment Variables
#   • Netlify: Site Settings → Environment Variables
#   • Render:  Environment → Environment Variables
#
# Without these, serverless functions will fail silently in production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase Configuration ───────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Server Port (local dev only) ─────────────────────────────────────────────
PORT=3001

# ── Authentication ───────────────────────────────────────────────────────────
# Bcrypt-hashed password (12 rounds). NEVER store plaintext passwords.
# Generate: node -e "require('bcryptjs').hash('YOUR_PASSWORD', 12).then(h => console.log(h))"
HASHED_PASSWORD=$2b$12$your-bcrypt-hash-here

# ── Email Alerts ─────────────────────────────────────────────────────────────
# Set ALERT_EMAIL_ENABLED=true to activate login email notifications.
# Requires Gmail App Password (NOT your regular Gmail password).
#
# How to get a Gmail App Password:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Create App Password: https://myaccount.google.com/apppasswords
#   3. Copy the 16-char code and paste below
#
ALERT_EMAIL_ENABLED=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
ALERT_EMAIL_TO=your-email@gmail.com
